  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())

  @@unique([assetCode, assetIssuer])
}

model UnifiedTransaction {
  id             String   @id @default(uuid())
  sourceAccount  String   @db.VarChar(56)
  network        String   @db.VarChar(20)
  txHash         String   @db.VarChar(64)
  type           String   @db.VarChar(30)
  subType        String?  @db.VarChar(50)
  amount         Decimal? @db.Decimal(30, 7)
  assetCode      String?  @db.VarChar(12)
  assetIssuer    String?  @db.VarChar(56)
  destination    String?  @db.VarChar(56)
  fee            Decimal? @db.Decimal(30, 7)
  memoType       String?  @db.VarChar(20)
  memoContent    String?
