  @@index([sourceAccount, createdAt])
}

model AnchorsRegistry {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(255)
  homeDomain     String   @db.VarChar(255)
  address        String?  @db.VarChar(56)
  assets         Json
  regions        String[]
  kycRequired    Boolean  @default(false)
  kycTypes       String[]
  fees           Json?
  limits         Json?
  supportedSeps  String[]
  isVerified     Boolean  @default(false)
  rating         Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount    Int      @default(0)
  status         String   @default("active") @db.VarChar(20)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  reviews AnchorReview[]

  @@index([homeDomain])
  @@index([status])
}

model AnchorReview {
  id        String   @id @default(uuid())
  anchorId  String
  reviewer  String   @db.VarChar(56)
  rating    Decimal  @db.Decimal(3, 2)
  comment   String?
  createdAt DateTime @default(now())

  anchor AnchorsRegistry @relation(fields: [anchorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([anchorId])
}

model BridgedAsset {
  id                    String   @id @default(uuid())
  classicAssetCode      String   @db.VarChar(12)
  classicAssetIssuer    String   @db.VarChar(56)
  sorobanContract       String   @unique @db.VarChar(56)
  bridgeProtocol        String   @db.VarChar(50)
  bridgeContract        String?  @db.VarChar(56)
  totalSupplyClassic    Decimal? @db.Decimal(30, 7)
  totalSupplySoroban    Decimal? @db.Decimal(30, 7)
  circulationClassic    Decimal? @db.Decimal(30, 7)
  circulationSoroban    Decimal? @db.Decimal(30, 7)
  lockedInBridge        Decimal? @db.Decimal(30, 7)
  totalBridgedVolume    Decimal? @db.Decimal(30, 0)
  bridgeFee             Decimal? @db.Decimal(5, 4)
  status                String   @default("active") @db.VarChar(20)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())
}

model StellarNetworkHealth {
  id                      BigInt   @id @default(autoincrement())
  nodeCount               Int?
  organizationCount       Int?
  countriesCount          Int?
  consensusRoundTimeMs    Int?
  ledgerCloseTimeMs       Int?
  latestLedgerSequence    BigInt?
  protocolVersion         Int?
  scpMessagesPerSecond    Decimal? @db.Decimal(10, 2)
