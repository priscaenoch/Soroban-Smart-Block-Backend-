  @@index([severity])
  @@index([victimAddress])
  @@index([acknowledged])
  @@index([createdAt])
}

// ─── Developer API Console & Key Management (#330) ───────────────────────────

enum DeveloperRole {
  admin
  user
  read_only
  restricted
}

enum KeyStatus {
  active
  revoked
  expired
  suspended
}

enum DeliveryStatus {
  success
  failed
  retrying
}

model BillingPlan {
  id            String   @id @default(cuid())
  name          String   @unique   // "free" | "developer" | "pro" | "enterprise"
  requestsPerDay Int
  requestsPerMonth Int
  priceMonthly  Float    @default(0)
  features      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  developers    Developer[]
}

model Developer {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String?
  githubId      String?        @unique
  walletAddress String?
  planId        String?
  plan          BillingPlan?   @relation(fields: [planId], references: [id])
  role          DeveloperRole  @default(user)
  emailVerified Boolean        @default(false)
  mfaEnabled    Boolean        @default(false)
  mfaSecret     String?
  devApiKeys    DevApiKey[]
  devWebhooks   DevWebhook[]
  usageRecords  UsageRecord[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([email])
}

model DevApiKey {
  id             String     @id @default(cuid())
  developerId    String
  developer      Developer  @relation(fields: [developerId], references: [id])
  keyPrefix      String
  keyHash        String
  name           String
  permissions    Json       @default("{}")
  allowedIps     Json?
  allowedDomains Json?
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  status         KeyStatus  @default(active)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  usageRecords   UsageRecord[]

  @@index([developerId])
  @@index([keyPrefix])
  @@index([status])
}

model DevWebhook {
  id                 String          @id @default(cuid())
  developerId        String
  developer          Developer       @relation(fields: [developerId], references: [id])
  url                String
  secret             String
  events             Json            @default("[]")
  retryPolicy        Json?
  headers            Json?
  active             Boolean         @default(true)
  lastDeliveryAt     DateTime?
  lastDeliveryStatus DeliveryStatus?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  devDeliveries      DevWebhookDelivery[]

  @@index([developerId])
}

model DevWebhookDelivery {
  id           String      @id @default(cuid())
  webhookId    String
  webhook      DevWebhook  @relation(fields: [webhookId], references: [id])
  eventType    String
  payload      Json
  statusCode   Int?
  responseBody String?
  durationMs   Int?
  attempt      Int         @default(1)
  delivered    Boolean     @default(false)
  deliveredAt  DateTime?
  createdAt    DateTime    @default(now())

  @@index([webhookId])
  @@index([delivered])
}

model UsageRecord {
  id          String     @id @default(cuid())
  developerId String
  developer   Developer  @relation(fields: [developerId], references: [id])
  apiKeyId    String?
  apiKey      DevApiKey? @relation(fields: [apiKeyId], references: [id])
  endpoint    String
  method      String
  statusCode  Int
  latencyMs   Int        @default(0)
  ipAddress   String?
  createdAt   DateTime   @default(now())

  @@index([developerId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
}

// ─── End Developer API Console & Key Management ───────────────────────────────

// ─── Soroban Temporal Orchestrator (Issue #310) ───────────────────────────────

enum TimerType {
  TIMELOCK
  VESTING
  DEADLINE
  COOLDOWN
  RECURRING
  TIME_WEIGHTED
  MULTI_STAGE
  ABSOLUTE
}

enum TimerStatus {
  PENDING
  ACTIVE
  EXECUTED
  EXPIRED
  CANCELLED
  FAILED
}

model ScheduledOperation {
  id              String      @id @default(cuid())
  contractAddress String      @map("contract_address")
  timerType       TimerType   @map("timer_type")
  status          TimerStatus
  functionName    String      @map("function_name")
  description     String?
  triggerTime     DateTime    @map("trigger_time")
  windowStart     DateTime?   @map("window_start")
  windowEnd       DateTime?   @map("window_end")
  intervalSeconds Int?        @map("interval_seconds")
  recurrenceCount Int?        @map("recurrence_count")
  eventsExecuted  Int         @default(0) @map("events_executed")
  parameters      Json?
  sourceTx        String?     @map("source_tx")
  createdBy       String?     @map("created_by")
  detectedAt      DateTime    @map("detected_at")
  lastExecutedAt  DateTime?   @map("last_executed_at")
  nextTriggerAt   DateTime?   @map("next_trigger_at")

  @@index([contractAddress])
  @@index([timerType])
  @@index([status])
  @@index([nextTriggerAt])
  @@index([triggerTime])
  @@map("scheduled_operations")
}

model VestingSchedule {
  id               String    @id @default(cuid())
  contractAddress  String    @map("contract_address")
  tokenAddress     String    @map("token_address")
  tokenSymbol      String?   @map("token_symbol")
  beneficiary      String
  totalAmount      Decimal   @map("total_amount")
  cliffDate        DateTime? @map("cliff_date")
  cliffAmount      Decimal?  @map("cliff_amount")
  startDate        DateTime  @map("start_date")
  endDate          DateTime  @map("end_date")
  vestingType      String    @map("vesting_type")
  periodSeconds    Int?      @map("period_seconds")
  amountPerPeriod  Decimal?  @map("amount_per_period")
  periodsTotal     Int?      @map("periods_total")
  nextUnlockDate   DateTime? @map("next_unlock_date")
  nextUnlockAmount Decimal?  @map("next_unlock_amount")
  totalUnlocked    Decimal   @default(0) @map("total_unlocked")
  totalClaimed     Decimal   @default(0) @map("total_claimed")
  status           String
  sourceTx         String?   @map("source_tx")
  detectedAt       DateTime  @map("detected_at")

  @@index([beneficiary])
  @@index([contractAddress])
  @@index([nextUnlockDate])
  @@index([status])
  @@map("vesting_schedules")
}

model GovernanceTimelock {
  id              String    @id @default(cuid())
  contractAddress String    @map("contract_address")
  proposalId      String?   @map("proposal_id")
  title           String?
  description     String?
  proposer        String
  executor        String?
  targets         Json
  values          Json
  calldatas       Json
  operationHash   String?   @map("operation_hash")
  queuedAt        DateTime  @map("queued_at")
  minDelay        Int       @map("min_delay")
  executionTime   DateTime  @map("execution_time")
  expiryTime      DateTime? @map("expiry_time")
  status          String
  executedTx      String?   @map("executed_tx")
  cancelledBy     String?   @map("cancelled_by")
  gracePeriod     Int?      @map("grace_period")

  @@index([contractAddress])
  @@index([status])
  @@index([executionTime])
  @@map("governance_timelocks")
}

model CronJob {
  id              String    @id @default(cuid())
  contractAddress String    @map("contract_address")
  cronExpression  String    @map("cron_expression")
  functionName    String    @map("function_name")
  functionArgs    Json      @map("function_args")
  description     String?
  lastRunAt       DateTime? @map("last_run_at")
  nextRunAt       DateTime? @map("next_run_at")
  totalRuns       Int       @default(0) @map("total_runs")
  successfulRuns  Int       @default(0) @map("successful_runs")
  failedRuns      Int       @default(0) @map("failed_runs")
  maxRuns         Int?      @map("max_runs")
  enabled         Boolean   @default(true)
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @map("created_at")

  executions CronExecution[]

  @@index([contractAddress])
  @@index([nextRunAt])
  @@map("cron_jobs")
}

model CronExecution {
  id           String   @id @default(cuid())
  cronJobId    String   @map("cron_job_id")
  executedAt   DateTime @map("executed_at")
  success      Boolean
  txHash       String?  @map("tx_hash")
  errorMessage String?  @map("error_message")
  gasUsed      Int?     @map("gas_used")
  duration     Int?

  cronJob CronJob @relation(fields: [cronJobId], references: [id])

  @@index([cronJobId, executedAt(sort: Desc)])
  @@map("cron_executions")
}

model TimerAlert {
  id            String   @id @default(cuid())
  scheduledOpId String?  @map("scheduled_op_id")
  alertType     String   @map("alert_type")
  severity      String
  title         String
  message       String
  triggerTime   DateTime @map("trigger_time")
  delivered     Boolean  @default(false)
  acknowledged  Boolean  @default(false)

  @@index([scheduledOpId])
  @@index([triggerTime])
  @@map("timer_alerts")
}

// ─── End Soroban Temporal Orchestrator ────────────────────────────────────────

// ─── Data Mesh - Multi-Channel Real-Time Streaming Platform ─────────────────

model FeedChannel {
  id                String   @id @default(cuid())
  name              String   @unique
  description       String?
  category          String   // "transaction" | "event" | "ledger" | "derived"
  schema            Json     // JSON Schema for the channel data
  retentionDays     Int      @default(30) @map("retention_days")
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("feed_channels")
}

model FeedSubscription {
  id                String   @id @default(cuid())
  userId            String?  @map("user_id")
  channelName       String   @map("channel_name")
  filters           Json?    // channel-specific filters
  deliveryType      String   // "webhook" | "websocket" | "sse" | "queue"
  deliveryConfig    Json     @map("delivery_config")
  status            String   // "active" | "paused" | "error"
  batchSize         Int      @default(1) @map("batch_size")
  maxRatePerSecond  Int?     @map("max_rate_per_second")
  createdAt         DateTime @default(now()) @map("created_at")
  lastDeliveryAt    DateTime? @map("last_delivery_at")
  totalDelivered    Int      @default(0) @map("total_delivered")
  totalFailed       Int      @default(0) @map("total_failed")
  lastError         String?  @map("last_error")

  @@index([userId])
  @@index([channelName])
  @@index([status])
  @@map("feed_subscriptions")
}

model FeedMessage {
  id              String   @id @default(cuid())
  channelName     String   @map("channel_name")
  sequence        BigInt   @unique
  data            Json
  dataVersion     Int      @default(1) @map("data_version")
  ledgerSequence  Int      @map("ledger_sequence")
  timestamp       DateTime
  indexedAt       DateTime @default(now()) @map("indexed_at")

  @@index([channelName, sequence])
  @@index([channelName, timestamp])
  @@index([ledgerSequence])
  @@map("feed_messages")
}

model BackfillRequest {
  id              String   @id @default(cuid())
  userId          String?  @map("user_id")
  channelName     String   @map("channel_name")
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  format          String   // "jsonl" | "csv" | "parquet" | "arrow" | "json"
  filters         Json?
  status          String   // "pending" | "processing" | "completed" | "failed"
  progress        Float    @default(0)
  fileUrl         String?  @map("file_url")
  fileSizeBytes   Int?     @map("file_size_bytes")
  recordCount     Int?     @map("record_count")
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([channelName, status])
  @@map("backfill_requests")
}

model DerivedMetric {
  id              String   @id @default(cuid())
  name            String
  timestamp       DateTime
  value           Float
  metadata        Json?
  granularity     String   // "1m" | "5m" | "15m" | "1h" | "1d"

  @@index([name, timestamp])
  @@index([name, granularity, timestamp(sort: Desc)])
  @@map("derived_metrics")
}

model MarketDataSnapshot {
  id              String   @id @default(cuid())
  tokenAddress    String   @map("token_address")
  tokenSymbol     String?  @map("token_symbol")
  timestamp       DateTime
  priceUsd        Float?   @map("price_usd")
  volume24h       Decimal? @map("volume_24h")
  tvl             Decimal?
  liquidity       Decimal?
  priceChange1h   Float?   @map("price_change_1h")
  priceChange24h  Float?   @map("price_change_24h")
  trades24h       Int?     @map("trades_24h")
  uniqueTraders24h Int?    @map("unique_traders_24h")

  @@index([tokenAddress, timestamp(sort: Desc)])
  @@map("market_data_snapshots")
}

// ─── End Data Mesh Platform ─────────────────────────────────────────────────
// ────────────────────────────────────────────────────────────────────────
// 🔮 Predictive Analytics & Forecasting Engine
// ────────────────────────────────────────────────────────────────────────

model FeatureDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  category    String?
  expression  String?
  granularity String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  values      FeatureValue[]

  @@map("feature_definitions")
}

model FeatureValue {
  id          BigInt   @id @default(autoincrement())
  featureId   String
  timestamp   DateTime
  value       Float
  blockNumber BigInt?

  feature     FeatureDefinition @relation(fields: [featureId], references: [id])

  @@unique([featureId, timestamp])
  @@index([timestamp])
  @@map("feature_values")
}

model ForecastMetric {
  id          String   @id @default(uuid())
  name        String   @unique
  models      ModelRegistry[]

  @@map("forecast_metrics")
}

model ModelRegistry {
  id                      String   @id @default(uuid())
  modelName               String
  modelVersion            String
  modelType               String?
  metricId                String?
  parameters              Json?
  features                Json?
  trainingDate            DateTime?
  trainingDurationSeconds Int?
  metrics                 Json?
  artifactPath            String?
  status                  String?
  createdAt               DateTime @default(now())

  metric                  ForecastMetric? @relation(fields: [metricId], references: [id])
  accuracies              PredictionAccuracy[]

  @@map("model_registry")
}

model PredictionAccuracy {
  id              BigInt   @id @default(autoincrement())
  modelId         String
  predictionId    String?
  metric          String
  granularity     String?
  predictedValue  Float?
  actualValue     Float?
  error           Float?
  absoluteError   Float?
  percentageError Float?
  timestamp       DateTime
  createdAt       DateTime @default(now())

  model           ModelRegistry @relation(fields: [modelId], references: [id])

  @@index([modelId, timestamp])
  @@map("prediction_accuracy")
}

model PredictionScenario {
  id              String   @id @default(uuid())
  baseForecastId  String?
  scenarioName    String   @unique
  perturbations   Json
  horizon         Int
  createdAt       DateTime @default(now())

  @@map("prediction_scenarios")
}

model ExternalDataSource {
  id                  String   @id @default(uuid())
  name                String   @unique
  type                String?
  baseUrl             String?
  apiKeyRequired      Boolean  @default(false)
  rateLimitPerMinute  Int?
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())

  dataPoints          ExternalDataPoint[]

  @@map("external_data_sources")
}

model ExternalDataPoint {
  id          BigInt   @id @default(autoincrement())
  sourceId    String
  metricName  String
  value       Float
  timestamp   DateTime
  metadata    Json?

  source      ExternalDataSource @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, metricName, timestamp])
  @@index([timestamp])
  @@map("external_data_points")
}

model PredictiveAlertRule {
  id              String   @id @default(uuid())
  name            String   @unique
  metric          String
  condition       String   // e.g. ">"
  threshold       Float
  horizonDays     Int
  action          String?  // "email", "webhook"
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@map("predictive_alert_rules")
}

model PredictiveApiKey {
  id              String   @id @default(uuid())
  key             String   @unique
  tier            String   @default("free") // "free", "pro", "enterprise"
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime?

  @@map("predictive_api_keys")
}
