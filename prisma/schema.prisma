  opportunityId String
  snapshotDate  DateTime
  apy           Float?
  baseApy       Float?
  incentiveApy  Float?
  tvl           Float?
  ledgerSequence Int
  createdAt     DateTime @default(now())
}

model YieldOpportunity {
  id              String    @id @default(cuid())
  contractAddress String
  name            String
  type            String
  tokens          String[]
  baseApy         Float?
  incentiveApy    Float?
  totalApy        Float?
  tvl             Float?
  lockupDays      Int?
  minDeposit      String?
  depositFee      Float?
  withdrawFee     Float?
  riskScore       Float?
  riskLabel       String?
  lastObservedAt  DateTime?
  createdAt       DateTime  @default(now())
