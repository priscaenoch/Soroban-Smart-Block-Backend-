// ─── Soroban Reentrancy Fortress (Issue #307) ────────────────────────────────

enum ReentrancyType {
  SIMPLE
  CROSS_CONTRACT
  MULTI_STEP
  READ_ONLY
  CROSS_FUNCTION
  DESTRUCTIVE
}

enum ReentrancySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CallGraphVertex {
  id              String   @id @default(cuid())
  txHash          String   @map("tx_hash")
  contractAddress String   @map("contract_address")
  functionName    String   @map("function_name")
  depth           Int
  callIndex       Int      @map("call_index")
  value           String?
  preStateReads   Json?    @map("pre_state_reads")
  postStateWrites Json?    @map("post_state_writes")
  timestamp       DateTime

  @@index([txHash])
  @@index([contractAddress])
  @@map("call_graph_vertices")
}

model CallGraphEdge {
  id            String   @id @default(cuid())
  txHash        String   @map("tx_hash")
  fromVertexId  String   @map("from_vertex_id")
  toVertexId    String   @map("to_vertex_id")
  functionName  String   @map("function_name")
  value         String?
  gasForwarded  Int?     @map("gas_forwarded")
  argsHash      String?  @map("args_hash")
  callIndex     Int      @map("call_index")
  timestamp     DateTime

  @@index([txHash])
  @@index([fromVertexId])
  @@index([toVertexId])
  @@map("call_graph_edges")
}

model ReentrancyFinding {
  id              String            @id @default(cuid())
  txHash          String            @map("tx_hash")
  contractAddress String            @map("contract_address")
  reentrancyType  ReentrancyType    @map("reentrancy_type")
  severity        ReentrancySeverity
  likelihood      String
  loopPath        Json
  entryPoint      String            @map("entry_point")
  valueAtRisk     String?           @map("value_at_risk")
  usdValueAtRisk  Float?            @map("usd_value_at_risk")
  profitPotential Float?            @map("profit_potential")
  description     String
  detectedAt      DateTime          @map("detected_at")

  @@index([txHash])
  @@index([contractAddress])
  @@index([severity])
  @@map("reentrancy_findings")
}

model ContractRiskScore {
  id                String   @id @default(cuid())
  contractAddress   String   @unique @map("contract_address")
  riskScore         Int      @map("risk_score")
  previousScore     Int?     @map("previous_score")
  totalFindings     Int      @map("total_findings")
  criticalFindings  Int      @map("critical_findings")
  highFindings      Int      @map("high_findings")
  mediumFindings    Int      @map("medium_findings")
  riskFactors       Json     @map("risk_factors")
  lastAnalyzed      DateTime @map("last_analyzed")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("contract_risk_scores")
}

model ReentrancyAlertExtended {
  id              String   @id @default(cuid())
  contractAddress String   @map("contract_address")
  findingId       String?  @map("finding_id")
  alertType       String   @map("alert_type")
  severity        String
  message         String
  metadata        Json?
  createdAt       DateTime @map("created_at")
  acknowledged    Boolean  @default(false)
  acknowledgedAt  DateTime? @map("acknowledged_at")

  @@index([contractAddress, createdAt(sort: Desc)])
  @@map("reentrancy_alerts")
}

model ReentrancyStats {
  id                  String   @id @default(cuid())
  timestamp           DateTime
  totalCallGraphs     Int      @map("total_call_graphs")
  contractsAnalyzed   Int      @map("contracts_analyzed")
  contractsWithLoops  Int      @map("contracts_with_loops")
  highRiskContracts   Int      @map("high_risk_contracts")
  criticalFindings    Int      @map("critical_findings")
  totalFindings       Int      @map("total_findings")
  mostCommonPatterns  Json     @map("most_common_patterns")
  avgDepth            Float?   @map("avg_depth")
  maxDepth            Int?     @map("max_depth")
  valueAtRiskTotal    String?  @map("value_at_risk_total")

  @@map("reentrancy_stats")
}

// ── Natural Language Query Interface (#328) ───────────────────────────────────

enum QueryFeedback {
  helpful
  not_helpful
  incorrect
  partial
}

model NlQuery {
  id               String         @id @default(cuid())
  userId           String?
  query            String
  language         String?
  interpretedQuery Json?
  sql              String?
  apiEndpoint      String?
  resolved         Boolean        @default(false)
  responseTime     Int?
  tokensUsed       Int?
  feedback         QueryFeedback?
  createdAt        DateTime       @default(now())

  context      NlQueryContext?
  savedQueries SavedQuery[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("nl_queries")
}

model NlQueryContext {
  id               String   @id @default(cuid())
  queryId          String   @unique @map("query_id")
  query            NlQuery  @relation(fields: [queryId], references: [id])
  sessionId        String?  @map("session_id")
  previousQueries  Json?    @map("previous_queries")
  resolvedEntities Json?    @map("resolved_entities")
  activeFilters    Json?    @map("active_filters")
  contextWindow    Int      @default(5) @map("context_window")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("nl_query_contexts")
}

model NlSession {
  id        String   @id @default(cuid())
  userId    String?
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("nl_sessions")
}

model SavedQuery {
  id         String    @id @default(cuid())
  userId     String?
  name       String
  nlTemplate String    @map("nl_template")
  parameters Json?
  schedule   String?
  lastRun    DateTime? @map("last_run")
  nextRun    DateTime? @map("next_run")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  queryId    String?   @map("query_id")
  query      NlQuery?  @relation(fields: [queryId], references: [id])

  @@index([userId])
  @@map("saved_queries")
}

model NlEmbedding {
  id          String   @id @default(cuid())
  query       String   @unique
  embedding   Bytes
  intent      String
  filters     Json?
  usageCount  Int      @default(0) @map("usage_count")
  successRate Float    @default(0) @map("success_rate")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("nl_embeddings")
}

model NlQueryTemplate {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?
  nlTemplate  String   @map("nl_template")
  parameters  Json?
  category    String?
  usageCount  Int      @default(0) @map("usage_count")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublic])
  @@index([category])
  @@map("nl_query_templates")
}

model NlReport {
  id          String    @id @default(cuid())
  userId      String?
  name        String
  nlTemplate  String    @map("nl_template")
  parameters  Json?
  schedule    String?
  reportType  String    @default("one-time") @map("report_type")
  webhookUrl  String?   @map("webhook_url")
  email       String?
  active      Boolean   @default(true)
  lastRun     DateTime? @map("last_run")
  nextRun     DateTime? @map("next_run")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  history NlReportHistory[]

  @@index([userId])
  @@map("nl_reports")
}

model NlReportHistory {
  id        String   @id @default(cuid())
  reportId  String   @map("report_id")
  report    NlReport @relation(fields: [reportId], references: [id])
  status    String
  result    Json?
  error     String?
  ranAt     DateTime @default(now()) @map("ran_at")

  @@index([reportId, ranAt(sort: Desc)])
  @@map("nl_report_history")
}

model NlAlert {
  id          String   @id @default(cuid())
  userId      String?
  nlQuery     String   @map("nl_query")
  intent      String
  conditions  Json?
  webhookUrl  String?  @map("webhook_url")
  email       String?
  active      Boolean  @default(true)
  lastFired   DateTime? @map("last_fired")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([active])
  @@map("nl_alerts")
}
