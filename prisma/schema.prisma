model EmergencyState {
  id                       String   @id @default(cuid())
  contractAddress          String   @unique @db.VarChar(56)
  isPaused                 Boolean  @default(false)
  currentPauseId           String?
  totalPauseCount          Int      @default(0)
  totalPausedSeconds       BigInt   @default(0)
  lastPauseDurationSeconds BigInt?
  pauserType               String?  @db.VarChar(30)
  decentralizationScore    Decimal? @db.Decimal(5, 2)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @default(now())

  @@index([contractAddress])
}

model PauseEvent {
  id              String   @id @default(cuid())
  contractAddress String   @db.VarChar(56)
  eventType       String   @db.VarChar(20)
  pauserAddress   String?  @db.VarChar(56)
  reason          String?
  txHash          String   @db.VarChar(64)
  blockNumber     BigInt
  timestamp       DateTime
  durationSeconds BigInt?
  gasCost         BigInt?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([contractAddress])
  @@index([eventType])
  @@index([timestamp])
  @@index([pauserAddress])
}

model PauserAnalysis {
  id                  String   @id @default(cuid())
  contractAddress     String   @unique @db.VarChar(56)
  pauserType          String   @db.VarChar(30)
  pauserAddresses     String[]
  unpauserAddresses   String[]
  threshold           Int?
  totalSigners        Int?
  timelockDelaySeconds BigInt?
  governanceContract  String?  @db.VarChar(56)
  automaticTriggers   Json?
  analysisMethod      String?  @db.VarChar(30)
  lastAnalyzed        DateTime @default(now())
}

model RecoveryAnalysis {
  id                      String   @id @default(cuid())
  contractAddress         String   @unique @db.VarChar(56)
  hasFundRecovery         Boolean  @default(false)
  fundRecoveryFunctions   String[]
  hasUpgradeCapability    Boolean  @default(false)
  upgradeFunctions        String[]
  hasMigrationCapability  Boolean  @default(false)
  migrationFunctions      String[]
  hasStateRollback        Boolean  @default(false)
  rollbackFunctions       String[]
  recoveryRobustnessScore Decimal? @db.Decimal(5, 2)
  analysisDetails         Json?
  lastAnalyzed            DateTime @default(now())
}

model AlertConfiguration {
  id               String   @id @default(cuid())
  userId           String
  contractAddress  String?  @db.VarChar(56)
  name             String?  @db.VarChar(255)
  alertType        String   @db.VarChar(50)
  conditions       Json?
  channels         Json
  isActive         Boolean  @default(true)
  cooldownMinutes  Int      @default(60)
  lastTriggeredAt  DateTime?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([contractAddress])
}

model IncidentReport {
  id                    String   @id @default(cuid())
  contractAddress       String   @db.VarChar(56)
  severity              String   @db.VarChar(20)
  status                String   @default("open") @db.VarChar(20)
  pauseEventId          String?
  title                 String   @db.VarChar(255)
  description           String?
  timeline              Json?
  affectedUsersEstimate BigInt?
  affectedTvlEstimate   Decimal? @db.Decimal(30, 0)
  rootCause             String?
  resolutionNotes       String?
  resolvedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())

  incidentComments IncidentComment[]

  @@index([contractAddress])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

model IncidentComment {
  id          String   @id @default(cuid())
  incidentId  String
  author      String
  body        String
  createdAt   DateTime @default(now())

  incident IncidentReport @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

model ProtocolHealthScore {
  id                     String   @id @default(cuid())
  contractAddress        String   @unique @db.VarChar(56)
  protocolName           String?  @db.VarChar(255)
  totalPauses30d         Int      @default(0)
  totalPauses90d         Int      @default(0)
  avgPauseDuration30d    BigInt?
  totalDowntime30d       BigInt?
  lastPauseDate          DateTime?
  recoveryScore          Decimal? @db.Decimal(5, 2)
  decentralizationScore  Decimal? @db.Decimal(5, 2)
  healthScore            Decimal? @db.Decimal(5, 2)
  riskLevel              String?  @db.VarChar(20)
  computedAt             DateTime @default(now())

  @@index([healthScore])
}

