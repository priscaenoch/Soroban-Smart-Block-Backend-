  profile ReputationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model VolumeAlert {
  id              String   @id @default(cuid())
  contractAddress String
  acknowledged    Boolean
  baseline        Float?
  currentCount    Int?
  detectedAt      DateTime
  severity        String?
  stdDev          Float?
  message         String?
  windowMinutes   Int?
  zScore          Float?
  createdAt       DateTime @default(now())
}

model VulnerabilitySource {
  id          String    @id @default(cuid())
  name        String    @unique
  sourceType  String
  feedUrl     String?
  lastFetchAt DateTime?
  active      Boolean
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WebhookDelivery {
  id             String    @id @default(cuid())
  subscriptionId String
  eventId        String?
  attempt        Int?
  status         String?
  httpStatus     Int?
  responseBody   String?
  errorMsg       String?
  deliveredAt    DateTime?
  nextRetryAt    DateTime?
  createdAt      DateTime  @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model WebhookSubscription {
  id              String    @id @default(cuid())
  url             String
  secret          String?
  contractAddress String?
  eventType       String?
  topicSymbol     String?
  active          Boolean
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  delivery WebhookDelivery[]
}

model YieldDistribution {
  id              String   @id @default(cuid())
  transactionHash String
  contractAddress String
  distributionId  String
  recipient       String
  amount          String?
  tokenSymbol     String?
  windowLabel     String?
  ledgerSequence  Int
  ledgerCloseTime DateTime
  createdAt       DateTime @default(now())
}

model YieldHistorySnapshot {
